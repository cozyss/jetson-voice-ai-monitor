# Base runtime state directory. Keep logs/recordings here; do not commit it.
VOICE_AI_BASE=/workspace/voice-ai

# Audio device; run `arecord -l` to find yours. EMEET on the demo Jetson was plughw:2,0.
VOICE_ARECORD_DEVICE=plughw:2,0
VOICE_TTS_AUDIO_DEVICE=plughw:2,0

# Local model services / binaries
VOICE_QWEN_URL=http://127.0.0.1:8083/v1/chat/completions
VOICE_WHISPER_BIN=/workspace/whisper.cpp/build/bin/whisper-cli
VOICE_WHISPER_MODEL=/workspace/models/whisper/ggml-base.en.bin
VOICE_PIPER_BIN=/workspace/piper/piper/piper
VOICE_PIPER_MODEL=/workspace/models/piper/en_US-ryan-high.onnx
VOICE_SYSTEM_PIPER_MODEL=/workspace/models/piper/en_US-lessac-high.onnx

# Behavior
VOICE_LIVE_TRANSCRIBE_ENABLED=1
VOICE_TOOL_CALLING_ENABLED=1
VOICE_TTS_ENABLED=1
VOICE_HISTORY_ENABLED=1
VOICE_QWEN_MAX_TOKENS=1024
VOICE_DASHBOARD_PORT=7862

# Optional online/self-improvement hooks; leave empty for offline-only demo.
OPENROUTER_API_KEY=
VOICE_SELF_IMPROVE_API_KEY=
VOICE_SELF_IMPROVE_AGENT_ID=
# Spoken-answer policy
# Ordinary spoken answers are shortened for voice unless a detailed answer is requested.
VOICE_QWEN_SPOKEN_DEFAULT_MAX_TOKENS=160
# Offline education self-improvement loop
VOICE_KB_ENABLED=1
VOICE_KB_MAX_CONTEXT_CHARS=2400
VOICE_KB_FETCH_TIMEOUT=12
VOICE_QA_REVIEW_MAX_ITEMS=200
VOICE_ANSWER_QUALITY_ENABLED=1
VOICE_ANSWER_QUALITY_THRESHOLD=0.72
VOICE_WEAK_ANSWER_MAX_ITEMS=200
VOICE_CONNECTIVITY_MODE=connect_to_internet_demo
# Optional online judge used only for explicit review/enrichment flows.
VOICE_SYSTEM_JUDGE_ENABLED=0
VOICE_SYSTEM_JUDGE_MODEL=openai/gpt-4o-mini
VOICE_SYSTEM_JUDGE_REQUIRE_INTERNET=1
VOICE_SYSTEM_JUDGE_TIMEOUT=8
VOICE_NONSENSE_INPUT_MAX_ITEMS=200
VOICE_INPUT_FILTER_ENABLED=1

# Optional hackathon telemetry/tracing with Weights & Biases.
# Leave disabled for fully offline/private deployments.
VOICE_WANDB_ENABLED=0
WANDB_PROJECT=self-improving-jetson-tutor
WANDB_RUN_NAME=jetson-tutor-demo
WANDB_API_KEY=
VOICE_WANDB_MAX_CHARS=1200
