[Unit]
Description=Jetson Voice AI Monitor daemon
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/workspace/jetson-voice-ai-monitor
EnvironmentFile=-/workspace/jetson-voice-ai-monitor/.env
Environment=PYTHONPATH=/workspace/jetson-voice-ai-monitor/src
ExecStart=/usr/bin/python3 -m jetson_voice_ai_monitor.voice_daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
